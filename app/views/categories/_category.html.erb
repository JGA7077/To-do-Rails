<div id="<%= dom_id category %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <h2 class="font-bold text-2xl mb-1">
      <%= category.name %>
    </h2>
  </div>

  <div class="grid gap-2 grid-cols-1 sm:grid-cols-2 md:grid-cols-5">
    <% category.todos.each do |todo| %>
      <%= render "todo", todo: todo  %>
    <% end %>
  </div>
</div>
