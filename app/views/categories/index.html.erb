<% content_for :title, "Categories" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Categories</h1>
    <%= link_to "New category", new_category_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <div id="categories" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @categories.any? %>
      <% @categories.each do |category| %>
        <div class="flex flex-col sm:flex-row justify-between items-start pb-5 sm:pb-0">
          <%= render category %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 my-6 space-y-2">
            <%= link_to "Show", category, class: "w-[60px] h-[45px] text-center rounded-md py-2.5 bg-gray-100 hover:bg-gray-50 text-slate-900 inline-block font-medium" %>
            <%= link_to "Edit", edit_category_path(category), class: "w-[60px] h-[45px] text-center rounded-md py-2.5 bg-gray-100 hover:bg-gray-50 text-slate-900 inline-block font-medium" %>
            <%= button_to category,
              method: :delete,
              class: "w-[60px] h-[45px] rounded-md py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer flex items-center justify-center",
              data: { turbo_confirm: "Are you sure?" } do %>
              <svg xmlns="http://www.w3.org/2000/svg" 
                  class="w-5 h-5" 
                  fill="none" 
                  viewBox="0 0 24 24" 
                  stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M6 7h12M9 7V5h6v2m-7 4v6m4-6v6m4-6v6M5 7h14l-1 12H6L5 7z"/>
              </svg>

            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No categories found.</p>
    <% end %>
  </div>
</div>
